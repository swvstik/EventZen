# ── EventZen ASP.NET Budget Service — Local Development ───────────────────────
# Put these keys in the shared repo env file: ../../../.env
# (optional) you can also copy this file to .env in this folder.
# dotenv.net loads from local .env first, then shared parent .env files.
# In Docker / CI: set real environment variables instead (this file is gitignored).
#
# ASP.NET Core maps double-underscore (__) to colon (:) in config keys:
#   MongoDB__ConnectionString  →  MongoDB:ConnectionString  in IConfiguration

# ── MongoDB ────────────────────────────────────────────────────────────────────
MongoDB__ConnectionString=mongodb://localhost:27017
MongoDB__DatabaseName=eventzen_budget

# ── JWT ────────────────────────────────────────────────────────────────────────
# MUST be identical to JWT_SECRET in ../../../.env
JWT__Secret=your_super_secret_key_here_change_this

# ── Spring Event Service (ownership checks) ──────────────────────────────────
Spring__BaseUrl=http://localhost:8082
Spring__InternalSecret=eventzen_internal_secret_change_me

# ── Node Payment Service (platform fee aggregates) ───────────────────────────
Node__BaseUrl=http://localhost:8081
Node__InternalSecret=eventzen_internal_secret_change_me

# ── Kafka (cross-service async messaging) ────────────────────────────────────
Kafka__Enabled=true
Kafka__BootstrapServers=localhost:9094
Kafka__ClientId=eventzen-dotnet-budget
Kafka__EventLifecycleTopic=eventzen.event.lifecycle
Kafka__PaymentTopic=eventzen.payment.lifecycle
Kafka__RegistrationTopic=eventzen.registration.lifecycle

# ── CORS ──────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins=http://localhost:3000,http://localhost:8080

# ── ASP.NET Core ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8083
