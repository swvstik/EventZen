{
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "eventzen_budget"
  },
  "Spring": {
    "BaseUrl": "http://localhost:8082",
    "InternalSecret": "eventzen_internal_secret_change_me"
  },
  "Node": {
    "BaseUrl": "http://localhost:8081",
    "InternalSecret": "eventzen_internal_secret_change_me"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "EventZen": "Debug"
    }
  },
  "Kafka": {
    "Enabled": true,
    "BootstrapServers": "localhost:9094",
    "ClientId": "eventzen-dotnet-budget-dev",
    "EventLifecycleTopic": "eventzen.event.lifecycle",
    "PaymentTopic": "eventzen.payment.lifecycle",
    "RegistrationTopic": "eventzen.registration.lifecycle",
    "VenueBookingsTopic": "eventzen.venue.bookings"
  },
  "VenueAllocationReconciliation": {
    "Enabled": true,
    "IntervalMinutes": 15
  }
}
