# ── EventZen Spring Boot Service — Environment Variables ──────────────────────
# Put these keys in the shared repo env file: ../../.env
# (optional) you can also copy this file to .env in this folder.
# IntelliJ: Run Configuration → EnvFile → add .env
# Docker:   set these in docker-compose.yml environment: section

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8082

# ── MySQL ──────────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/eventzen?serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password_here
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ── JWT ────────────────────────────────────────────────────────────────────────
# MUST be identical to JWT_SECRET in ../../.env
JWT_SECRET=your_super_secret_key_here_change_this

# ── Internal service secret ────────────────────────────────────────────────────
# MUST match INTERNAL_SERVICE_SECRET in ../../.env
INTERNAL_SERVICE_SECRET=eventzen_internal_secret_change_me

# ── Node service base URL (attendee count + cancellation sync) ───────────────
NODE_SERVICE_BASE_URL=http://localhost:8081

# ── Kafka (cross-service async messaging) ────────────────────────────────────
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_EVENT_LIFECYCLE_TOPIC=eventzen.event.lifecycle

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
