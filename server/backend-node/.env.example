# Shared setup: put these keys in ../../.env (repo root), or copy this file
# to .env in this folder for service-only local runs.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8081

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/eventzen_node

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST match jwt.secret in ../backend-spring/src/main/resources/application.properties
JWT_SECRET=your_super_secret_key_here_must_match_spring_service
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
TOKEN_HASH_SECRET=set-a-different-secret-from-jwt-secret

# ── Cross-service ─────────────────────────────────────────────────────────────
# Spring Boot base URL — used by RegistrationService to validate events + tier capacity
SPRING_BASE_URL=http://localhost:8082

# Internal secret — for Node.js → Spring Boot /api/events/:id/rating calls (future)
INTERNAL_SERVICE_SECRET=eventzen_internal_secret_change_me

# Kafka (global async messaging)
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9094
KAFKA_CLIENT_ID=eventzen-node
KAFKA_EVENT_LIFECYCLE_TOPIC=eventzen.event.lifecycle
KAFKA_REGISTRATION_TOPIC=eventzen.registration.lifecycle
KAFKA_PAYMENT_TOPIC=eventzen.payment.lifecycle

# ── Nodemailer (Gmail App Password) ───────────────────────────────────────────
# Get App Password: myaccount.google.com → Security → 2-Step → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password

# ── MinIO object storage ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eventzen-media
MINIO_PUBLIC_BASE_URL=http://localhost:8080/media

# ── Polar checkout (sandbox) ────────────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxxxxxxxxxxx
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID=your_polar_product_id

# ── Client URL (used in email deep-links) ───────────────────────────────────
CLIENT_URL=http://localhost:8080

# ── CORS / proxy ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# Behind Nginx/Render proxy keep this as 1
TRUST_PROXY=1

# Keep false for local HTTP; set true behind HTTPS in production.
COOKIE_SECURE=false
