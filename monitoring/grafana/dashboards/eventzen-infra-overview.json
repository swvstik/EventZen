{
  "id": null,
  "uid": "eventzen-infra-overview",
  "title": "EventZen Infrastructure Overview",
  "tags": ["eventzen", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Prometheus Targets Up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(up)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Nginx Connections",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "nginx_connections_active"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "MongoDB Operations",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (state) (rate(mongodb_ss_opcounters_total[5m]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "MySQL Questions",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mysql_global_status_questions[5m])"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka Broker Messages In",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kafka_server_brokertopicmetrics_messagesin_total[5m]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "MinIO Requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(minio_s3_requests_total[5m]))"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" }
}
