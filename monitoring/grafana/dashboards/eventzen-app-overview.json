{
  "id": null,
  "uid": "eventzen-app-overview",
  "title": "EventZen App Overview",
  "tags": ["eventzen", "application"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate (rps)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate({__name__=~\"eventzen_node_http_requests_total|http_server_requests_seconds_count|http_requests_received_total\"}[5m]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 5xx Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate({__name__=~\"eventzen_node_http_requests_total|http_server_requests_seconds_count|http_requests_received_total\",status_code=~\"5..\"}[5m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Node Process CPU Seconds",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(eventzen_node_process_cpu_user_seconds_total[5m])"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Container Memory Working Set",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"node-service|spring-service|dotnet-service\"})"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" }
}
