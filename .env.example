# EventZen - Environment Variables (Vault-first)
# Copy this file to .env and fill in values:
#   cp .env.example .env
# One-command startup (auto wrapped token):
#   ./scripts/start-local.ps1
# Docker Compose reads .env automatically from the project root.

# Vault connectivity and auth bootstrap controls
VAULT_ENABLED=true
VAULT_ADDR=http://127.0.0.1:8200
VAULT_DOCKER_ADDR=http://host.docker.internal:8200
VAULT_SKIP_TLS_VERIFY=true
VAULT_KV_MOUNT=secret
VAULT_KV_PATH=eventzen/ez-secrets

# Shared bootstrap token wiring (single policy + single secret path)
EZ_VAULT_WRAP_PATH=auth/token/create
VAULT_WRAPPED_SECRET_ID=

# One wrapped token per compose startup (consumed by vault-secrets-init)

# Non-secret app config still passed from Compose
GATEWAY_HOST_PORT=8080
GATEWAY_HEALTH_URL=http://localhost:8080/health
CLIENT_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
TRUST_PROXY=1
COOKIE_SECURE=false
POLAR_SERVER=sandbox
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=eventzen-media
MINIO_PUBLIC_BASE_URL=http://localhost:8080/media

# Database host ports (change only if defaults conflict on your machine)
MONGO_HOST_PORT=27018
MYSQL_HOST_PORT=3307

# Object storage host ports (change only if defaults conflict on your machine)
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Infra secrets (kept in .env for now; third-party images do not run Vault wrapper)
MYSQL_ROOT_PASSWORD=change-me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Kafka (global async messaging)
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_HOST_PORT=9094
KAFKA_EVENT_LIFECYCLE_TOPIC=eventzen.event.lifecycle
KAFKA_REGISTRATION_TOPIC=eventzen.registration.lifecycle
KAFKA_PAYMENT_TOPIC=eventzen.payment.lifecycle
NODE_KAFKA_CLIENT_ID=eventzen-node
DOTNET_KAFKA_CLIENT_ID=eventzen-dotnet-budget

# Monitoring stack (Prometheus + Grafana)
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
