# ── EventZen — Environment Variables ─────────────────────────────────────
# Copy this file to `.env` and fill in the values.
#
#   cp .env.example .env
#
# Docker Compose reads this file automatically from the project root.
# ──────────────────────────────────────────────────────────────────────────

# Secrets (REQUIRED — generate strong random strings)
JWT_SECRET=change-me-to-a-strong-random-string
INTERNAL_SERVICE_SECRET=change-me-to-another-random-string
TOKEN_HASH_SECRET=change-me-to-a-third-random-string
MYSQL_ROOT_PASSWORD=change-me

# SMTP — used for sending OTP / password-reset emails (REQUIRED)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Client URL — used for CORS and email links
CLIENT_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database host ports (change only if defaults conflict on your machine)
MONGO_HOST_PORT=27018
MYSQL_HOST_PORT=3307

# MinIO object storage (local, persistent via Docker volume)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=eventzen-media
MINIO_PUBLIC_BASE_URL=http://localhost:8080/media
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Polar checkout (sandbox)
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxxxxxxxxxxx
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID=your_polar_product_id

# Kafka (global async messaging)
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_HOST_PORT=9094
KAFKA_EVENT_LIFECYCLE_TOPIC=eventzen.event.lifecycle
KAFKA_REGISTRATION_TOPIC=eventzen.registration.lifecycle
KAFKA_PAYMENT_TOPIC=eventzen.payment.lifecycle
NODE_KAFKA_CLIENT_ID=eventzen-node
DOTNET_KAFKA_CLIENT_ID=eventzen-dotnet-budget

# Optional — reverse proxy trust (1 = trust first proxy)
TRUST_PROXY=1

# Optional — auth cookie transport hardening
# Keep false for local HTTP; set true behind HTTPS in production.
COOKIE_SECURE=false
